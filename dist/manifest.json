{
  "manifest_version": 3,
  "name": "EcoSense",
  "version": "1.0.0",
  "description": "Behavioral carbon intelligence assistant for hybrid workers.",
  "action": {
    "default_popup": "index.html#/popup",
    "default_title": "EcoSense"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
